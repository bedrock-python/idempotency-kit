{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "release-type": "python",
      "package-name": "idempotency-kit",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        {
          "type": "generic",
          "path": "idempotency_kit/__version__.py",
          "search": "__version__ = \"$1\""
        }
      ]
    }
  }
}
